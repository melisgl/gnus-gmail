#!/bin/bash

# Listen to the system bus for logind sleep signals
dbus-monitor --system "type='signal',interface='org.freedesktop.login1.Manager',member='PrepareForSleep'" | while read -r line; do
    # 'boolean false' indicates the system is waking up
    if [[ "$line" == *"boolean false"* ]]; then
        systemctl --user restart goimapnotify.service
    fi
done
